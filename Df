end

-- Safe Value Spoofer
local function SpoofValue(object, property, value)
    if not object or not property then return end
    
    local success, err = pcall(function()
        local oldValue = object[property]
        
        -- Hook the value
        hookfunction(object[property], function()
            return oldValue
        end)
        
        -- Set new value silently
        local success = pcall(function()
            object[property] = value
        end)
        
        if success then
            SpoofedValues[object] = {
                Property = property,
                Original = oldValue,
                Spoofed = value
            }
        end
    end)
    
    return success
end

-- Restore spoofed values
local function RestoreSpoofed()
    for object, data in pairs(SpoofedValues) do
        pcall(function()
            object[data.Property] = data.Original
        end)
    end
end

