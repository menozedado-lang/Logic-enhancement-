-- Hook CheatDetectedEvent
local function HookAntiCheat()
    -- Method 1: Replace the remote event
    local OldEvent = CheatDetectedEvent
    
    -- Create fake event
    local FakeEvent = {
        FireServer = function(...) 
            print("Anti-cheat blocked: FireServer")
            return nil 
        end,
        InvokeServer = function(...) 
            print("Anti-cheat blocked: InvokeServer") 
            return nil 
        end,
        OnClientEvent = {
            Connect = function(...) 
                print("Anti-cheat blocked: Connect")
                return {Disconnect = function() end}
            end
        }
    }
    
    -- Replace in ReplicatedStorage
    CheatDetectedEvent = FakeEvent
    
    -- Method 2: Hook metatable
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    OriginalNamecall = mt.__namecall
    OriginalIndex = mt.__index
    OriginalNewIndex = mt.__newindex
    
    -- Hook namecall (FireServer/InvokeServer)
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        if self == OldEvent or self.Name == "CheatDetectedEvent" then
            if method == "FireServer" or method == "InvokeServer" then
                print("Blocked anti-cheat: " .. method)
                return nil
            end
        end
        return OriginalNamecall(self, ...)
    end)
    
    -- Hook index
    mt.__index = newcclosure(function(self, key)
        if self == OldEvent or (typeof(self) == "Instance" and self.Name == "CheatDetectedEvent") then
            if key == "FireServer" or key == "InvokeServer" then
                return function() 
                    print("Blocked anti-cheat index: " .. tostring(key))
                    return nil 
                end
            end
        end
        return OriginalIndex(self, key)
    end)
    
    setreadonly(mt, true)
    AntiCheatBypassed = true
    print("Anti-cheat bypassed!")
end

-- Additional Anti-Cheat Bypass Methods
local function AdditionalBypass()
