UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Config.Safety.EmergencyKey then
        Config.Ragebot.Enabled = false
        Config.AntiAim.Enabled = false
        Config.Main.Enabled = false
        isHiding = false
        isAttacking = false
        RestorePosition()
        if camera then
            camera.FieldOfView = 70
        end
        Rayfield:Notify({
            Title = "Emergency Stop",
            Content = "All features disabled!",
            Duration = 3,
        })
    end
end)

