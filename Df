    WeaponStatus.Parent = Section
    
    local PosStatus = Instance.new("TextLabel")
    PosStatus.Name = "PosStatus"
    PosStatus.Size = UDim2.new(1, -20, 0, 20)
    PosStatus.Position = UDim2.new(0, 10, 0, 55)
    PosStatus.BackgroundTransparency = 1
    PosStatus.Text = "Position: Normal"
    PosStatus.TextColor3 = Color3.fromRGB(150, 150, 150)
    PosStatus.TextSize = 11
    PosStatus.Font = Enum.Font.Gotham
    PosStatus.TextXAlignment = Enum.TextXAlignment.Left
    PosStatus.Parent = Section
    
    Section.Parent = parent
    
    return VoidStatus, WeaponStatus, PosStatus
end

function CreateEmergencyButton(parent, position)
    local EmergencyBtn = Instance.new("TextButton")
    EmergencyBtn.Name = "EmergencyBtn"
    EmergencyBtn.Size = UDim2.new(1, -20, 0, 40)
    EmergencyBtn.Position = position
    EmergencyBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    EmergencyBtn.Text = "🛑 EMERGENCY STOP (DELETE KEY)"
    EmergencyBtn.TextColor3 = Color3.new(1, 1, 1)
    EmergencyBtn.TextSize = 14
    EmergencyBtn.Font = Enum.Font.GothamBold
    
    local EmergencyCorner = Instance.new("UICorner")
    EmergencyCorner.CornerRadius = UDim.new(0, 8)
    EmergencyCorner.Parent = EmergencyBtn
    
    -- Pulse animation
    local TweenIn = TweenService:Create(EmergencyBtn, TweenInfo.new(0.5), {BackgroundColor3 = Color3.fromRGB(255, 50, 50)})
    local TweenOut = TweenService:Create(EmergencyBtn, TweenInfo.new(0.5), {BackgroundColor3 = Color3.fromRGB(200, 0, 0)})
    
    spawn(function()
        while EmergencyBtn.Parent do
            TweenIn:Play()
            wait(0.5)
            TweenOut:Play()
            wait(0.5)
        end
    end)
    
    EmergencyBtn.Parent = parent
    
    return EmergencyBtn
end

-- ============================================
-- UI INTERACTIONS & LOGIC
-- ============================================

function SetupUIInteractions()
    local ScreenGui, MainFrame, TitleBar, MinimizeBtn, CloseBtn = CreateCustomUI()
    
    -- Create Sections
    local VoidToggle, MethodButtons, MethodText, IntensityLabel, IntensityFill = CreateVoidspamSection(MainFrame, UDim2.new(0, 10, 0, 50))
    local SpeedLabel, SpeedFill, SpeedValue, InstantBtn, WeaponLabels = CreateWeaponSection(MainFrame, UDim2.new(0, 10, 0, 240))
    local VoidStatus, WeaponStatus, PosStatus = CreateStatusSection(MainFrame, UDim2.new(0, 10, 0, 390))
    local EmergencyBtn = CreateEmergencyButton(MainFrame, UDim2.new(0, 10, 0, 480))
    
    -- Minimize functionality
    local minimized = false
    MinimizeBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            MainFrame:TweenSize(UDim2.new(0, 350, 0, 40), Enum.EasingDirection.Out, Enum.EasingStyle.Quart, 0.3)
            MinimizeBtn.Text = "+"
        else
            MainFrame:TweenSize(UDim2.new(0, 350, 0, 530), Enum.EasingDirection.Out, Enum.EasingStyle.Quart, 0.3)
            MinimizeBtn.Text = "-"
        end
    end)
    
    -- Close functionality
    CloseBtn.MouseButton1Click:Connect(function()
        -- Disable everything before closing
        VoidspamEnabled = false
        ResetWeaponSpeeds()
        EmergencyStop()
        
        MainFrame:TweenSize(UDim2.new(0, 0, 0, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quart, 0.3, false, function()
            ScreenGui:Destroy()
        end)
    end)
    
    -- Voidspam Toggle
    VoidToggle.MouseButton1Click:Connect(function()
        VoidspamEnabled = not VoidspamEnabled
        
        if VoidspamEnabled then
            VoidToggle.Text = "ENABLED"
            VoidToggle.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
            VoidToggle.TextColor3 = Color3.new(1, 1, 1)
            VoidStatus.Text = "Voidspam: ON - " .. VoidMethod
            VoidStatus.TextColor3 = Color3.fromRGB(0, 255, 100)
        else
            VoidToggle.Text = "DISABLED"
            VoidToggle.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
            VoidToggle.TextColor3 = Color3.fromRGB(255, 80, 80)
            VoidStatus.Text = "Voidspam: OFF"
            VoidStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
            EmergencyStop()
        end
    end)
    
    -- Method Selection
    for method, btn in pairs(MethodButtons) do
        btn.MouseButton1Click:Connect(function()
            VoidMethod = method
            
            -- Update visual
            for _, b in pairs(MethodButtons) do
                b.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
                b.TextColor3 = Color3.fromRGB(150, 150, 150)
            end
            btn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
            btn.TextColor3 = Color3.new(1, 1, 1)
            
            MethodText.Text = method
            
            if VoidspamEnabled then
                VoidStatus.Text = "Voidspam: ON - " .. method
            end
        end)
    end
    
    -- Set default method visual
    MethodButtons["Extreme"].BackgroundColor3 = Color3.fromRGB(0, 150, 255)
    MethodButtons["Extreme"].TextColor3 = Color3.new(1, 1, 1)
    
    -- Intensity Slider Interaction
    local slidingIntensity = false
    
    IntensityFill.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            slidingIntensity = true
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            slidingIntensity = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if slidingIntensity and input.UserInputType == Enum.UserInputType.MouseMovement then
            local sliderPos = IntensityFill.Parent.AbsolutePosition.X
            local sliderWidth = IntensityFill.Parent.AbsoluteSize.X
            local mouseX = input.Position.X
            
            local percent = math.clamp((mouseX - sliderPos) / sliderWidth, 0, 1)
            DesyncIntensity = math.floor(percent * 100)
            
            IntensityFill.Size = UDim2.new(percent, 0, 1, 0)
            IntensityLabel.Text = "Intensity: " .. DesyncIntensity .. "%"
        end
    end)
    
    -- Weapon Speed Slider
    local slidingSpeed = false
    
    SpeedFill.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            slidingSpeed = true
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            slidingSpeed = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if slidingSpeed and input.UserInputType == Enum.UserInputType.MouseMovement then
            local sliderPos = SpeedFill.Parent.AbsolutePosition.X
            local sliderWidth = SpeedFill.Parent.AbsoluteSize.X
            local mouseX = input.Position.X
            
            local percent = math.clamp((mouseX - sliderPos) / sliderWidth, 0, 1)
            local speed = math.floor(percent * 100)
            
            SpeedFill.Size = UDim2.new(percent, 0, 1, 0)
            SpeedValue.Text = speed .. "%"
            
            -- Update weapons
            UpdateAllWeaponSpeeds(speed)
            
            -- Update label
            if speed == 0 then
                SpeedLabel.Text = "Fire Rate: 0% (Normal)"
                SpeedLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
                WeaponStatus.Text = "Weapons: Normal"
                WeaponStatus.TextColor3 = Color3.fromRGB(150, 150, 150)
            elseif speed == 100 then
                SpeedLabel.Text = "Fire Rate: 100% (INSTANT)"
                SpeedLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
                WeaponStatus.Text = "Weapons: INSTANT FIRE"
                WeaponStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
            else
                SpeedLabel.Text = "Fire Rate: " .. speed .. "% (Fast)"
                SpeedLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
                WeaponStatus.Text = "Weapons: " .. speed .. "% Faster"
                WeaponStatus.TextColor3 = Color3.fromRGB(255, 200, 100)
            end
            
            -- Update weapon label colors
            for weapon, label in pairs(WeaponLabels) do
                if speed > 0 then
                    label.TextColor3 = Color3.fromRGB(0, 255, 100)
                else
                    label.TextColor3 = Color3.fromRGB(150, 150, 150)
                end
            end
        end
    end)
    
    -- Instant Fire Button
    InstantBtn.MouseButton1Click:Connect(function()
        SpeedFill.Size = UDim2.new(1, 0, 1, 0)
        SpeedValue.Text = "100%"
        SpeedLabel.Text = "Fire Rate: 100% (INSTANT)"
        SpeedLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
        WeaponStatus.Text = "Weapons: INSTANT FIRE"
        WeaponStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
        
        UpdateAllWeaponSpeeds(100)
        
        for weapon, label in pairs(WeaponLabels) do
            label.TextColor3 = Color3.fromRGB(0, 255, 100)
        end
    end)
    
    -- Emergency Button
    EmergencyBtn.MouseButton1Click:Connect(function()
        EmergencyStop()
        VoidspamEnabled = false
        
        -- Reset UI
        VoidToggle.Text = "DISABLED"
        VoidToggle.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
        VoidToggle.TextColor3 = Color3.fromRGB(255, 80, 80)
        VoidStatus.Text = "Voidspam: OFF (EMERGENCY)"
        VoidStatus.TextColor3 = Color3.fromRGB(255, 0, 0)
    end)
    
    -- Update position status
    RunService.RenderStepped:Connect(function()
        if VoidspamEnabled and hrp then
            local pos = hrp.Position
            PosStatus.Text = string.format("Server sees: %.0f, %.0f, %.0f", pos.X, pos.Y, pos.Z)
            PosStatus.TextColor3 = Color3.fromRGB(255, 100, 255)
        else
            PosStatus.Text = "Position: Normal"
            PosStatus.TextColor3 = Color3.fromRGB(150, 150, 150)
        end
    end)
    
    -- Make draggable
    local dragging = false
    local dragStart = nil
    local startPos = nil
    
    TitleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    return ScreenGui
end

