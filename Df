-- Random Method - Switches between patterns
local LastPatternSwitch = 0
local CurrentPattern = "Extreme"

VoidMethods["Random"] = function()
    if tick() - LastPatternSwitch > 0.5 then
        local patterns = {"Extreme", "Fast", "Slow"}
        CurrentPattern = patterns[math_random(1, #patterns)]
        LastPatternSwitch = tick()
    end
    
    VoidMethods[CurrentPattern]()
end

