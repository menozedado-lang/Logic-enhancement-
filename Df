local function IsAlive(player)
    if not player or not player.Character then return false end
    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
    return humanoid and humanoid.Health > 0
end

local function GetClosestPlayer()
    local closest, closestDistance = nil, math.huge
    local screenCenter = Vector2.new(
        Camera.ViewportSize.X / 2,
        Camera.ViewportSize.Y / 2
    )

    for _, player in ipairs(players:GetPlayers()) do
        if player ~= localPlayer and IsAlive(player) then
            local character = player.Character
            local rootPart = character:FindFirstChild("HumanoidRootPart")

            if rootPart then
                if Config.SilentAim.IgnoreProtected 
                and character:FindFirstChildOfClass("ForceField") then
                    continue
                end

                local screenPos, onScreen = Camera:WorldToViewportPoint(
                    rootPart.Position
                )
                if not onScreen then continue end

                local screenPos2D = Vector2.new(screenPos.X, screenPos.Y)
                local distance = (screenCenter - screenPos2D).Magnitude

                if distance <= Config.SilentAim.Radius 
                and distance < closestDistance then
                    closest = player
                    closestDistance = distance
                end
            end
        end
    end

    return closest
end

local function GetClosestPart(character)
    if not character then return nil end

    local closest, closestDistance = nil, math.huge
    local screenCenter = Vector2.new(
        Camera.ViewportSize.X / 2,
        Camera.ViewportSize.Y / 2
    )

    for _, part in ipairs(character:GetChildren()) do
        if part:IsA("BasePart") then
            local screenPos, onScreen = Camera:WorldToViewportPoint(
                part.Position
            )
            if onScreen then
                local screenPos2D = Vector2.new(screenPos.X, screenPos.Y)
                local distance = (screenCenter - screenPos2D).Magnitude

                if distance < closestDistance then
                    closest = part
                    closestDistance = distance
                end
            end
        end
    end

    return closest
end

--[[
    ═══════════════════════════════════════════════
                    SILENT AIM
    ═══════════════════════════════════════════════
]]

local utility = require(replicatedStorage.Modules.Utility)
local originalRaycast = utility.Raycast

utility.Raycast = function(...)
    local args = {...}

    if Config.SilentAim.Enabled and args[4] == 999 then
        local target = GetClosestPlayer()

        if target then
            SilentAimTarget = target

            if math.random(100) <= Config.SilentAim.HitChance then
                local targetPart

                if Config.SilentAim.ClosestPart then
                    targetPart = GetClosestPart(target.Character)
                else
                    targetPart = target.Character:FindFirstChild("Head")
                end

                if targetPart then
                    args[3] = targetPart.Position
                end
            end
        else
            SilentAimTarget = nil
        end
    end

    return originalRaycast(...)
end

--[[
    ═══════════════════════════════════════════════
                    AIMBOT
    Fixed: Uses Camera.CFrame instead of
    CameraController if not found
    ═══════════════════════════════════════════════
]]

Connections.Aimbot = runService.RenderStepped:Connect(function()
    if not Config.Aimbot.Enabled then return end

    local target = GetClosestPlayer()

    if target then
        AimbotTarget = target
        local character = target.Character
        local targetPart = character:FindFirstChild("Head")

        if targetPart then
            if CameraController then
                -- Use CameraController if found
                pcall(function()
                    local dir = (
                        targetPart.Position - Camera.CFrame.Position
                    ).Unit
                    local pitch = math.asin(-dir.Y)
                    local yaw = math.atan2(-dir.X, -dir.Z)
                    CameraController:SetRotation(
                        Vector2.new(pitch, yaw)
                    )
                end)
            else
                -- Fallback: Move camera directly
                Camera.CFrame = Camera.CFrame:Lerp(
                    CFrame.new(
                        Camera.CFrame.Position,
                        targetPart.Position
                    ),
                    0.2
                )
            end
        end
    else
        AimbotTarget = nil
    end
end)

--[[
    ═══════════════════════════════════════════════
                    TRIGGERBOT
    ═══════════════════════════════════════════════
]]

local lastShootTime = 0

Connections.Triggerbot = runService.Heartbeat:Connect(function()
    if not Config.Triggerbot.Enabled then return end

    if AimbotTarget or SilentAimTarget then
        local currentTime = tick()

        if currentTime - lastShootTime >= Config.Triggerbot.ShootDelay then
            task.wait(Config.Triggerbot.ReactionTime / 1000)

            local tool = localPlayer.Character 
                and localPlayer.Character:FindFirstChildOfClass("Tool")
            if tool then
                pcall(function() tool:Activate() end)
                lastShootTime = tick()
            end
        end
    end
end)

--[[
    ═══════════════════════════════════════════════
                RAGEBOT - FIXED VOID SPAM
    No more ReplicateUnreliable spam!
    ═══════════════════════════════════════════════
]]

local voidPosition = -380
local lastVoidTime = 0
local isInVoid = false

Connections.Ragebot = runService.Heartbeat:Connect(function()
    if not Config.Ragebot.Enabled then return end
    if not Config.Ragebot.VoidSpam then return end

    local character = localPlayer.Character
    if not character then return end

    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    local currentTime = tick()
    local currentPos = rootPart.Position

    -- Fixed: Proper timing instead of tick() % hide
    if not isInVoid then
        if currentTime - lastVoidTime >= Config.Ragebot.Attack then
            -- Go to void
            isInVoid = true
            lastVoidTime = currentTime
            pcall(function()
                rootPart.CFrame = CFrame.new(
                    currentPos.X,
                    voidPosition,
                    currentPos.Z
                )
                rootPart.AssemblyLinearVelocity = Vector3.zero
            end)
        end
    else
        if currentTime - lastVoidTime >= Config.Ragebot.Hide then
            -- Come back
            isInVoid = false
            lastVoidTime = currentTime
            pcall(function()
                rootPart.AssemblyLinearVelocity = Vector3.zero
            end)
        end
    end
end)

