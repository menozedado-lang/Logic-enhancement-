--[[
    ═══════════════════════════════════════════════════════
                    UTILITY FUNCTIONS
    ═══════════════════════════════════════════════════════
]]

local function IsAlive(player)
    if not player or not player.Character then return false end
    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
    return humanoid and humanoid.Health > 0
end

local function GetClosestPlayer()
    local closest, closestDistance = nil, math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, player in ipairs(players:GetPlayers()) do
        if player ~= localPlayer and IsAlive(player) then
            local character = player.Character
            local rootPart = character:FindFirstChild("HumanoidRootPart")
            
            if rootPart then
                -- Check if protected
                if Config.SilentAim.IgnoreProtected and character:FindFirstChildOfClass("ForceField") then
                    continue
                end
                
                local screenPos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
                if not onScreen then continue end
                
                local screenPos2D = Vector2.new(screenPos.X, screenPos.Y)
                local distance = (screenCenter - screenPos2D).Magnitude
                
                if distance <= Config.SilentAim.Radius and distance < closestDistance then
                    closest = player
                    closestDistance = distance
                end
            end
        end
    end
    
    return closest
end

local function GetClosestPart(character)
    if not character then return nil end
    
    local closest, closestDistance = nil, math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, part in ipairs(character:GetChildren()) do
        if part:IsA("BasePart") then
            local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
            if onScreen then
                local screenPos2D = Vector2.new(screenPos.X, screenPos.Y)
                local distance = (screenCenter - screenPos2D).Magnitude
                
                if distance < closestDistance then
                    closest = part
                    closestDistance = distance
                end
            end
        end
    end
    
    return closest
end

--[[
    ═══════════════════════════════════════════════════════
                    SILENT AIM
    ═══════════════════════════════════════════════════════
]]

local utility = require(replicatedStorage.Modules.Utility)
local originalRaycast = utility.Raycast

utility.Raycast = function(...)
    local args = {...}
    
    if Config.SilentAim.Enabled and args[4] == 999 then
        local target = GetClosestPlayer()
        
        if target then
            SilentAimTarget = target
            
            -- Hit chance
            if math.random(100) <= Config.SilentAim.HitChance then
                local targetPart
                
                if Config.SilentAim.ClosestPart then
                    targetPart = GetClosestPart(target.Character)
                else
                    targetPart = target.Character:FindFirstChild("Head")
                end
                
                if targetPart then
                    args[3] = targetPart.Position
                end
            end
        end
    end
    
    return originalRaycast(...)
end

--[[
    ═══════════════════════════════════════════════════════
                    AIMBOT
    ═══════════════════════════════════════════════════════
]]

local function CalculateAngles(targetPos)
    local cameraPos = Camera.CFrame.Position
    local direction = (targetPos - cameraPos).Unit
    
    local pitch = math.asin(-direction.Y)
    local yaw = math.atan2(-direction.X, -direction.Z)
    
    return Vector2.new(pitch, yaw)
end

Connections.Aimbot = runService.RenderStepped:Connect(function()
    if not Config.Aimbot.Enabled or not CameraController then return end
    
    local target = GetClosestPlayer()
    
    if target then
        AimbotTarget = target
        local character = target.Character
        local targetPart = character:FindFirstChild("Head")
        
        if targetPart then
            local angles = CalculateAngles(targetPart.Position)
            
            pcall(function()
                CameraController:SetRotation(angles)
            end)
        end
    else
        AimbotTarget = nil
    end
end)

--[[
    ═══════════════════════════════════════════════════════
                    TRIGGERBOT
    ═══════════════════════════════════════════════════════
]]

local lastShootTime = 0

Connections.Triggerbot = runService.Heartbeat:Connect(function()
    if not Config.Triggerbot.Enabled then return end
    
    if AimbotTarget or SilentAimTarget then
        local currentTime = tick()
        
        if currentTime - lastShootTime >= Config.Triggerbot.ShootDelay then
            task.wait(Config.Triggerbot.ReactionTime / 1000)
            
            local tool = localPlayer.Character and localPlayer.Character:FindFirstChildOfClass("Tool")
            if tool then
                tool:Activate()
                lastShootTime = currentTime
            end
        end
    end
end)

--[[
    ═══════════════════════════════════════════════════════
                    RAGEBOT (VOID SPAM)
    ═══════════════════════════════════════════════════════
]]

local voidPosition = -380

Connections.Ragebot = runService.Heartbeat:Connect(function()
    if not Config.Ragebot.Enabled then return end
    
    local character = localPlayer.Character
    if not character then return end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    if Config.Ragebot.VoidSpam then
        local currentPos = rootPart.Position
        local targetY = tick() % Config.Ragebot.Hide < 0.1 and voidPosition or currentPos.Y
        
        rootPart.CFrame = CFrame.new(currentPos.X, targetY, currentPos.Z)
        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    end
end)

--[[
