-- ESP Functions
local function CreateESP(object, text, color)
    if ESPObjects[object] then return end
    
    local esp = {
        Box = Drawing.new("Square"),
        Text = Drawing.new("Text"),
        Tracer = Drawing.new("Line")
    }
    
    esp.Box.Thickness = 1
    esp.Box.Filled = false
    esp.Box.Color = color or Color3.fromRGB(255, 0, 0)
    esp.Box.Transparency = 1
    
    esp.Text.Size = 14
    esp.Text.Center = true
    esp.Text.Outline = true
    esp.Text.Color = color or Color3.fromRGB(255, 255, 255)
    
    esp.Tracer.Thickness = 1
    esp.Tracer.Color = color or Color3.fromRGB(255, 255, 255)
    
    ESPObjects[object] = esp
end

local function UpdateESP()
    for object, esp in pairs(ESPObjects) do
        local isVisible = false
        
        if ESPEnabled and object and object.Parent then
            local pos, onScreen = Camera:WorldToViewportPoint(object.Position)
            if onScreen then
                isVisible = true
                esp.Box.Visible = true
                esp.Text.Visible = true
                esp.Tracer.Visible = true
                
                local size = Vector2.new(50, 50)
                esp.Box.Size = size
                esp.Box.Position = Vector2.new(pos.X - size.X/2, pos.Y - size.Y/2)
                
                esp.Text.Position = Vector2.new(pos.X, pos.Y - size.Y/2 - 15)
                esp.Text.Text = object.Name
                
                esp.Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                esp.Tracer.To = Vector2.new(pos.X, pos.Y)
            end
        end
        
        if not isVisible then
            esp.Box.Visible = false
            esp.Text.Visible = false
            esp.Tracer.Visible = false
        end
    end
end

RunService.RenderStepped:Connect(UpdateESP)

