-- Better random with dead zone avoidance
function betterRandom(mi, ma, dmi, dma)
    dmi = dmi or -1147483646
    dma = dma or 1147483646
    
    local val = math_random(mi, ma)
    local attempts = 0
    
    repeat
        val = math_random(mi, ma)
        attempts = attempts + 1
        if attempts > 100 then
            -- Force outside dead zone
            if math_random() > 0.5 then
                val = dmi - math_random(1, 1000000)
            else
                val = dma + math_random(1, 1000000)
            end
            break
        end
    until val < dmi or val > dma
    
    return val
end

-- Apply intensity scaling
function applyIntensity(value, intensity)
    intensity = intensity or DesyncIntensity
    if intensity >= 100 then return value end
    return math.floor(value * (intensity / 100))
end

-- Void Method Functions
local VoidMethods = {}

-- Extreme Method - Original extreme desync
VoidMethods["Extreme"] = function()
    local int32Min = -2147483646
    local int32Max = 2147483646
    local deadMin = -1147483646
    local deadMax = 1147483646
    
    local x = applyIntensity(betterRandom(int32Min, int32Max, deadMin, deadMax), DesyncIntensity)
    local y = applyIntensity(betterRandom(int32Min, int32Max, deadMin, deadMax), DesyncIntensity)
    local z = applyIntensity(betterRandom(int32Min, int32Max, deadMin, deadMax), DesyncIntensity)
    
    -- Random rotation
    local rx = math_rad(math_random() * math_pi * 2)
    local ry = math_rad(math_random() * math_pi * 2)
    local rz = math_rad(math_random() * math_pi * 2)
    
    hrp.CFrame = CFrame_new(x, y, z) * CFrame.Angles(rx, ry, rz)
    
    hrp.AssemblyLinearVelocity = Vector3_new(
        applyIntensity(betterRandom(int32Min, int32Max, deadMin, deadMax), DesyncIntensity) * 0.1,
        applyIntensity(betterRandom(int32Min, int32Max, deadMin, deadMax), DesyncIntensity) * 0.1,
        applyIntensity(betterRandom(int32Min, int32Max, deadMin, deadMax), DesyncIntensity) * 0.1
    )
    
    hrp.AssemblyAngularVelocity = Vector3_new(
        applyIntensity(betterRandom(int32Min, int32Max, deadMin, deadMax), DesyncIntensity) * 0.1,
        applyIntensity(betterRandom(int32Min, int32Max, deadMin, deadMax), DesyncIntensity) * 0.1,
        applyIntensity(betterRandom(int32Min, int32Max, deadMin, deadMax), DesyncIntensity) * 0.1
    )
end

-- Fast Method - Rapid smaller movements
