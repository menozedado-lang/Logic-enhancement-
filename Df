    speedFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    speedFrame.BorderSizePixel = 0
    speedFrame.Visible = false
    speedFrame.Parent = mobileGui
    
    local corner4 = Instance.new("UICorner")
    corner4.CornerRadius = UDim.new(0, 10)
