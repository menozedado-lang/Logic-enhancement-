-- Update line numbers
function BladeIDE.UpdateLineNumbers(textBox, lineNumbersLabel)
    local text = textBox.Text
    local lines = 1
    for _ in text:gmatch("\n") do
        lines = lines + 1
    end
    
    local lineText = ""
    for i = 1, lines do
        lineText = lineText .. i .. "\n"
    end
    
    lineNumbersLabel.Text = lineText
end

-- Simple syntax highlighter
function BladeIDE.HighlightSyntax(code)
    local highlighted = code
    
    -- Escape special HTML-like characters
    highlighted = highlighted:gsub("&", "&amp;")
    highlighted = highlighted:gsub("<", "&lt;")
    highlighted = highlighted:gsub(">", "&gt;")
    
    -- Comments
    highlighted = highlighted:gsub("(%-%-[^\n]*)", '<font color="#' .. Theme.Comment:ToHex() .. '">%1</font>')
    
    -- Strings (double quotes)
    highlighted = highlighted:gsub('("[^"]*")', '<font color="#' .. Theme.String:ToHex() .. '">%1</font>')
    
    -- Strings (single quotes)
    highlighted = highlighted:gsub("('[^']*')", '<font color="#' .. Theme.String:ToHex() .. '">%1</font>')
    
    -- Numbers
    highlighted = highlighted:gsub("(%d+%.?%d*)", '<font color="#' .. Theme.Number:ToHex() .. '">%1</font>')
    
    -- Keywords
    for _, keyword in ipairs(Keywords) do
        local pattern = "%f[%a](" .. keyword .. ")%f[^%a]"
        highlighted = highlighted:gsub(pattern, '<font color="#' .. Theme.Keyword:ToHex() .. '">%1</font>')
    end
    
    -- Functions (words followed by ()
    highlighted = highlighted:gsub("(%w+)(%s*%()", '<font color="#' .. Theme.Function:ToHex() .. '">%1</font>%2')
    
    return highlighted
end

-- Convert Color3 to hex
function Color3:ToHex()
    return string.format("%02X%02X%02X", self.R * 255, self.G * 255, self.B * 255)
end

