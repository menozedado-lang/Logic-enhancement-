            [16537449730] = 133426190455626,
            [13110130082] = 103022841301405
        }

        local function replaceSound(obj)
            for oldId, newId in pairs(replacements) do
                if obj.SoundId:find(tostring(oldId)) then
                    obj.SoundId = "rbxassetid://" .. tostring(newId)
                    return
                end
            end
        end

        for _, obj in ipairs(game:GetDescendants()) do
