local lastShootTime = 0

Connections.Triggerbot = runService.Heartbeat:Connect(function()
    if not Config.Triggerbot.Enabled then return end
    if not (AimbotTarget or SilentAimTarget) then return end

    local now = tick()
    if now - lastShootTime < Config.Triggerbot.ShootDelay then
        return
    end

    task.wait(Config.Triggerbot.ReactionTime / 1000)
    local tool = localPlayer.Character
        and localPlayer.Character:FindFirstChildOfClass("Tool")
    if tool then
        pcall(function() tool:Activate() end)
        lastShootTime = tick()
    end
end)

