local function ModifyWeapon(tool)
    if not tool or not tool:IsA("Tool") then return end
    
    pcall(function()
        if Config.Weapons.NoSpread then
            if tool:FindFirstChild("Spread") then
                tool.Spread.Value = 0
            end
        end
        
        if Config.Weapons.FullAuto then
            tool:SetAttribute("FireMode", "Auto")
        end
        
        if Config.Weapons.AlwaysBackstab then
            -- Backstab logic would go here
        end
    end)
end

localPlayer.Character.ChildAdded:Connect(function(child)
    if child:IsA("Tool") then
        ModifyWeapon(child)
    end
end)

if localPlayer.Character then
    for _, child in ipairs(localPlayer.Character:GetChildren()) do
        if child:IsA("Tool") then
            ModifyWeapon(child)
        end
    end
end

