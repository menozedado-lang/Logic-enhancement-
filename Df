-- Add console message
function BladeIDE.ConsolePrint(consoleScroll, text, messageType)
    messageType = messageType or "normal" -- normal, error, warning, success
    
    local colors = {
        normal = Theme.Text,
        error = Theme.Error,
        warning = Theme.Warning,
        success = Theme.Success,
        info = Theme.Accent
    }
    
    local prefix = {
        normal = "",
        error = "[ERROR] ",
        warning = "[WARN] ",
        success = "[OK] ",
        info = "[INFO] "
    }
    
    local message = Instance.new("TextLabel")
    message.Name = "Message"
    message.Size = UDim2.new(1, -10, 0, 20)
    message.BackgroundTransparency = 1
    message.Text = prefix[messageType] .. tostring(text)
    message.TextColor3 = colors[messageType]
    message.TextSize = 12
    message.Font = Enum.Font.Code
    message.TextXAlignment = Enum.TextXAlignment.Left
    message.TextWrapped = true
    message.Parent = consoleScroll
    
    -- Adjust canvas size
    local totalHeight = 0
    for _, child in ipairs(consoleScroll:GetChildren()) do
        if child:IsA("TextLabel") then
            totalHeight = totalHeight + 22
        end
    end
    
    consoleScroll.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
    consoleScroll.CanvasPosition = Vector2.new(0, totalHeight)
    
    return message
end

