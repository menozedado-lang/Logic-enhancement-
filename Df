-- Fixed CameraController
-- Search in correct place!
-- ━━━━━━━━━━━━━━━━━━━━━

local CameraController = nil

local function FindCameraController()
    -- Search multiple possible paths
    local paths = {
        -- Path 1
        function()
            return localPlayer.PlayerScripts
                :FindFirstChild("Controllers")
                and localPlayer.PlayerScripts.Controllers
                :FindFirstChild("CameraController")
        end,
        -- Path 2
        function()
            local scripts = localPlayer:FindFirstChild("PlayerScripts")
            if not scripts then return nil end
            for _, v in pairs(scripts:GetDescendants()) do
                if v.Name == "CameraController" then
                    return v
                end
            end
        end,
        -- Path 3
        function()
            for _, v in pairs(localPlayer.PlayerScripts:GetDescendants()) do
                if v.Name:find("Camera") then
                    print("Found camera related: " .. v:GetFullName())
                end
            end
            return nil
        end,
    }

    for _, path in pairs(paths) do
        local ok, result = pcall(path)
        if ok and result then
            print("✅ CameraController found: " .. result:GetFullName())
            return result
        end
    end

    print("⚠️ CameraController not found - Aimbot will use Camera.CFrame instead")
    return nil
end

-- Find without yielding forever
task.spawn(function()
    CameraController = FindCameraController()
end)

--[[
