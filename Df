-- Load template
function BladeIDE.LoadTemplate(name, textBox)
    if BladeIDE.Templates[name] then
        textBox.Text = BladeIDE.Templates[name]
        return true
    end
    return false
end

-- Initialize complete IDE
function BladeIDE.Init()
    local screenGui, mainFrame = BladeIDE.Create()
    local topbar, runBtn, clearBtn, saveBtn, loadBtn, closeBtn = BladeIDE.CreateTopbar(mainFrame)
    local sidebar, fileList, newFileBtn = BladeIDE.CreateSidebar(mainFrame)
    local textBox, lineNumbers, scrollFrame, highlightFrame = BladeIDE.CreateEditor(mainFrame)
    local consoleScroll, consoleInput, clearConsoleBtn = BladeIDE.CreateConsole(mainFrame)
    
    -- Current file tracking
    local currentFile = "untitled.blade"
    local files = {}
    
    -- Console print function
    local function consolePrint(text, msgType)
        BladeIDE.ConsolePrint(consoleScroll, text, msgType)
    end
    
    -- Update line numbers on text change
    textBox:GetPropertyChangedSignal("Text"):Connect(function()
        BladeIDE.UpdateLineNumbers(textBox, lineNumbers)
    end)
    
    -- Run button
    runBtn.MouseButton1Click:Connect(function()
        local code = textBox.Text
        if #code == 0 then
            consolePrint("No code to run!", "error")
            return
        end
        
        consolePrint("Compiling...", "info")
        
        local success, result = pcall(function()
            -- Check if Blade is loaded
            if not _G.Blade then
                -- Load Blade if not available
                loadstring(game:HttpGet('https://pastebin.com/raw/XXXXX'))() -- Replace with actual URL
            end
            
            return _G.Blade.Execute(code, {
                game = game,
                workspace = workspace,
                print = function(...) 
                    local args = {...}
                    local str = ""
                    for i, v in ipairs(args) do
                        str = str .. tostring(v) .. " "
                    end
                    consolePrint(str, "normal")
                end,
                wait = wait,
                spawn = spawn,
                delay = delay,
                tick = tick,
                time = time,
                typeof = typeof,
                type = type,
                pcall = pcall,
                xpcall = xpcall,
                error = error,
                assert = assert,
                math = math,
                table = table,
                string = string,
                coroutine = coroutine,
                debug = debug,
                os = os,
                ipairs = ipairs,
                pairs = pairs,
                next = next,
                tonumber = tonumber,
                tostring = tostring,
                unpack = unpack,
                select = select,
                rawget = rawget,
                rawset = rawset,
                rawequal = rawequal,
                setmetatable = setmetatable,
                getmetatable = getmetatable,
                _G = _G,
                shared = shared,
                script = script,
                require = require,
                loadstring = loadstring,
                Instance = Instance,
                Vector3 = Vector3,
                Vector2 = Vector2,
                Color3 = Color3,
                UDim = UDim,
                UDim2 = UDim2,
                CFrame = CFrame,
                Enum = Enum,
                Ray = Ray,
                Region3 = Region3,
                BrickColor = BrickColor,
                NumberRange = NumberRange,
                NumberSequence = NumberSequence,
                ColorSequence = ColorSequence
            })
        end)
        
        if success then
            consolePrint("Script executed successfully!", "success")
        else
            consolePrint("Error: " .. tostring(result), "error")
        end
    end)
    
    -- Clear button
    clearBtn.MouseButton1Click:Connect(function()
        textBox.Text = ""
        consolePrint("Editor cleared", "info")
    end)
    
    -- Save button
    saveBtn.MouseButton1Click:Connect(function()
        local code = textBox.Text
        if #code == 0 then
            consolePrint("Nothing to save!", "warning")
            return
        end
        
        files[currentFile] = code
        
        -- Save to file (using writefile if available)
        if writefile then
            local success, err = pcall(function()
                writefile(currentFile, code)
            end)
            if success then
                consolePrint("Saved to " .. currentFile, "success")
            else
                consolePrint("Save error: " .. tostring(err), "error")
            end
        else
            consolePrint("Saved to memory (writefile not available)", "success")
        end
    end)
    
    -- Load button
    loadBtn.MouseButton1Click:Connect(function()
        if readfile then
            local success, content = pcall(function()
                return readfile(currentFile)
            end)
            if success and content then
                textBox.Text = content
                consolePrint("Loaded " .. currentFile, "success")
            else
                consolePrint("Load error or file not found", "error")
            end
        else
            if files[currentFile] then
                textBox.Text = files[currentFile]
                consolePrint("Loaded from memory", "success")
            else
                consolePrint("No file in memory", "error")
            end
        end
    end)
    
    -- Close button
    closeBtn.MouseButton1Click:Connect(function()
        mainFrame:TweenSize(UDim2.new(0, 0, 0, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quart, 0.3, true, function()
            screenGui:Destroy()
        end)
    end)
    
    -- New file button
    newFileBtn.MouseButton1Click:Connect(function()
        currentFile = "script" .. (#files + 1) .. ".blade"
        textBox.Text = ""
        consolePrint("Created new file: " .. currentFile, "info")
    end)
    
    -- Clear console button
    clearConsoleBtn.MouseButton1Click:Connect(function()
        for _, child in ipairs(consoleScroll:GetChildren()) do
            if child:IsA("TextLabel") then
                child:Destroy()
            end
        end
        consoleScroll.CanvasSize = UDim2.new(0, 0, 0, 100)
    end)
    
    -- Console input
    consoleInput.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            local cmd = consoleInput.Text
            consolePrint("> " .. cmd, "info")
            
            -- Execute command
            local success, result = pcall(function()
                return loadstring(cmd)()
            end)
            
            if success then
                if result then
                    consolePrint(tostring(result), "normal")
                end
            else
                consolePrint(tostring(result), "error")
            end
            
            consoleInput.Text = ""
        end
    end)
    
    -- Create template buttons
    for templateName, _ in pairs(BladeIDE.Templates) do
        BladeIDE.CreateFileButton(templateName, fileList, function()
            BladeIDE.LoadTemplate(templateName, textBox)
            consolePrint("Loaded template: " .. templateName, "info")
        end)
    end
    
    -- Make draggable
    local dragging = false
    local dragStart = nil
    local startPos = nil
    
    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    -- Welcome message
    consolePrint("Blade IDE v" .. BladeIDE.Version .. " loaded!", "success")
    consolePrint("Select a template from the sidebar or start coding!", "info")
    
    return BladeIDE
end

