local currentColor = Color3.fromRGB(100, 0, 200)
local currentStroke = Color3.fromRGB(170, 0, 255)

local function ApplyWeaponColor()
    pcall(function()
        local handler = localPlayer
            :WaitForChild("PlayerScripts", 2)
            :WaitForChild("Modules", 2)
            :WaitForChild("WeaponStatusHandler", 2)
        if not handler then return end

        local WeaponStatusHandler = require(handler)
        local oldFunc = WeaponStatusHandler
            .ApplyItemStatusToBackground

        WeaponStatusHandler.ApplyItemStatusToBackground = function(
            self, background, stroke, status
        )
            background.BackgroundColor3 = currentColor
            if stroke then
                stroke.Color = currentStroke
                stroke.Thickness = 2
            end
            local parent = background.Parent
            if parent and parent:FindFirstChild("Icon") then
                parent.Icon.Picture.ImageTransparency = 0.1
            end
            return oldFunc(self, background, stroke, "Banned")
        end
    end)
    Library:Notify('✅ Weapon slot color applied', 2.5)
end

