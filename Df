local function ModifyWeapon(tool)
    if not tool or not tool:IsA("Tool") then return end

    pcall(function()
        if Config.Weapons.NoSpread then
            local spread = tool:FindFirstChild("Spread")
            if spread then spread.Value = 0 end
        end

        if Config.Weapons.FullAuto then
            tool:SetAttribute("FireMode", "Auto")
        end
    end)
end

-- Safe character child added
pcall(function()
    localPlayer.Character.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then
            ModifyWeapon(child)
        end
    end)
end)

localPlayer.CharacterAdded:Connect(function(char)
    -- Reset targets on respawn
    SilentAimTarget = nil
    AimbotTarget = nil
    isInVoid = false

    char.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then
            ModifyWeapon(child)
        end
    end)
end)

