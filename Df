    local corner5 = Instance.new("UICorner")
    corner5.CornerRadius = UDim.new(0, 5)
    corner5.Parent = speedSlider
    
    -- Parent to CoreGui or PlayerGui
    if syn then
        mobileGui.Parent = game:GetService("CoreGui")
