local consoleEnabled = true
local consoleTextColor = Color3.fromRGB(255, 255, 100)
local consoleDuration = 4
local consoleLabels = {}

local function showConsoleMessage(text)
    if not consoleEnabled then return end

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Text = "CONSOLE: " .. tostring(text)
    label.Font = Enum.Font.Code
    label.TextColor3 = consoleTextColor
    label.TextSize = 18
    label.TextStrokeTransparency = 0.7
    label.TextStrokeColor3 = Color3.new(0, 0, 0)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Size = UDim2.new(0.9, 0, 0, 30)
    label.Position = UDim2.new(
        0.05, 0,
        0.1 + (#consoleLabels * 0.06), 0
    )
    label.Parent = localPlayer:WaitForChild("PlayerGui")

    table.insert(consoleLabels, label)
    label.TextTransparency = 1

    game:GetService("TweenService"):Create(
        label, TweenInfo.new(0.3),
        {TextTransparency = 0}
    ):Play()

    task.delay(consoleDuration, function()
        if label and label.Parent then
            game:GetService("TweenService"):Create(
                label, TweenInfo.new(0.8),
                {TextTransparency = 1}
            ):Play()
            task.wait(0.8)
            label:Destroy()
        end
        local idx = table.find(consoleLabels, label)
        if idx then table.remove(consoleLabels, idx) end
    end)
end

local oldPrint = print
local oldWarn = warn

_G.print = function(...)
    local msg = table.concat({...}, " ")
    oldPrint(...)
    showConsoleMessage(msg)
end

_G.warn = function(...)
    local msg = table.concat({...}, " ")
    oldWarn(...)
    showConsoleMessage("[WARN] " .. msg)
end

