-- Main Loops - NO SAFETY CHECKS
RunService.Heartbeat:Connect(function()
    if not VoidspamEnabled then return end
    if not LocalPlayer.Character then return end
    
    hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    if hrp ~= lastHRP then
        clientCFrame = hrp.CFrame
        clientVelocity = hrp.AssemblyLinearVelocity
        clientAngularVelocity = hrp.AssemblyAngularVelocity
        lastHRP = hrp
    end
    
    local method = VoidMethods[VoidMethod]
    if method then method() end
end)

RunService:BindToRenderStep("VoidRestore", Enum.RenderPriority.First.Value, function()
    if not VoidspamEnabled then return end
    if not hrp then return end
    if clientCFrame then hrp.CFrame = clientCFrame end
    if clientVelocity then hrp.AssemblyLinearVelocity = clientVelocity end
    if clientAngularVelocity then hrp.AssemblyAngularVelocity = clientAngularVelocity end
end)

-- Emergency Stop Only
function EmergencyStop()
    VoidspamEnabled = false
    if hrp and clientCFrame then
        hrp.CFrame = clientCFrame
        hrp.AssemblyLinearVelocity = Vector3_new(0, 0, 0)
        hrp.AssemblyAngularVelocity = Vector3_new(0, 0, 0)
    end
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Delete then EmergencyStop() end
end)

