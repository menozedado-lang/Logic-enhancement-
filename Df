Connections.Ragebot = runService.Heartbeat:Connect(function()
    if not Config.Ragebot.Enabled then return end
    if not Config.Ragebot.VoidSpam then return end

    local char = localPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local now = tick()
    local pos = root.Position

    if not isInVoid then
        if now - lastVoidTime >= Config.Ragebot.Attack then
            isInVoid = true
            lastVoidTime = now
            pcall(function()
                root.CFrame = CFrame.new(pos.X, -380, pos.Z)
                root.AssemblyLinearVelocity = Vector3.zero
            end)
        end
    else
        if now - lastVoidTime >= Config.Ragebot.Hide then
            isInVoid = false
            lastVoidTime = now
            pcall(function()
                root.AssemblyLinearVelocity = Vector3.zero
            end)
        end
    end
end)

