        if v:IsA("RemoteFunction") and v.Name:lower():find("cheat") or v.Name:lower():find("detect") or v.Name:lower():find("ban") then
            v.InvokeServer = function(...)
                print("Blocked: " .. v.Name)
                return nil
            end
        end
