-- Better random with dead zone
function betterRandom(mi, ma, dmi, dma)
    dmi = dmi or -1147483646
    dma = dma or 1147483646
    local val = math_random(mi, ma)
    repeat val = math_random(mi, ma) until val < dmi or val > dma
    return val
end

function applyIntensity(value, intensity)
    if intensity >= 100 then return value end
    return math.floor(value * (intensity / 100))
end

-- Weapon Mods - NO LIMITS
function InitWeaponMods()
    pcall(function()
        ItemLibrary = require(ReplicatedStorage.Modules.ItemLibrary)
        local Items = rawget(ItemLibrary, "Items")
        if not Items then return end
        
        for _, Item in pairs(Items) do
            local Name = Item.Name
            if Name ~= "Bow" and Name ~= "Daggers" and Name ~= "Slingshot" then continue end
            if not Item["ReloadLength"] then continue end
            
            OriginalReloadLengths[Name] = Item.ReloadLength
        end
    end)
end

function SetWeaponSpeed(speedPercent)
    WeaponSpeed = speedPercent
    if not ItemLibrary then return end
    
    pcall(function()
        local Items = rawget(ItemLibrary, "Items")
        if not Items then return end
        
        for _, Item in pairs(Items) do
            local Name = Item.Name
            if Name ~= "Bow" and Name ~= "Daggers" and Name ~= "Slingshot" then continue end
            if not Item["ReloadLength"] then continue end
            
            local original = OriginalReloadLengths[Name] or Item.ReloadLength
            local newReload = original * (1 - (speedPercent / 100))
            
            -- NO SAFETY CAP - TRUE INSTANT
            rawset(Item, "ReloadLength", newReload)
        end
    end)
end

