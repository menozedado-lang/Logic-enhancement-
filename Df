--[[
    ═══════════════════════════════════════════════════════
                    SAFETY FEATURES
    ═══════════════════════════════════════════════════════
]]

LocalPlayer.CharacterAdded:Connect(function(character)
    if Config.Safety.AutoDisableOnDeath then
        Config.VoidSpam.Enabled = false
        Config.ProjectileTP.Enabled = false
        Config.Ragebot.Enabled = false
        
        hrp = nil
        
        character:WaitForChild("HumanoidRootPart", 5)
        task.wait(0.5)
    end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Config.Safety.EmergencyKey then
        Config.VoidSpam.Enabled = false
        Config.ProjectileTP.Enabled = false
        Config.Ragebot.Enabled = false
        
        if hrp and clientCFrame then
            hrp.CFrame = clientCFrame
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        end
        
        Library:Notify('Emergency Stop', 'All features disabled!', 3)
    end
end)

