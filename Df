--[[
    ═══════════════════════════════════════════════════════
                    UTILITY
    ═══════════════════════════════════════════════════════
]]

local function IsAlive(player)
    if not player or not player.Character then return false end
    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
    return humanoid and humanoid.Health > 0
end

local function GetClosestEnemy()
    local closest, closestDistance = nil, math.huge
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and IsAlive(player) then
            local character = player.Character
            local rootPart = character:FindFirstChild("HumanoidRootPart")
            if rootPart and LocalPlayer.Character then
                local myRoot = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if myRoot then
                    local distance = (myRoot.Position - rootPart.Position).Magnitude
                    if distance < closestDistance then
                        closest = player
                        closestDistance = distance
                    end
                end
            end
        end
    end
    return closest
end

--[[
    ═══════════════════════════════════════════════════════
                    VOID SPAM
    ═══════════════════════════════════════════════════════
]]

local function ApplyVoid()
    if not hrp then return end
    local range = 2147483646
    local deadZone = 1147483646

    local function betterRandom()
        local val
        repeat
            val = math.random(-range, range)
        until val < -deadZone or val > deadZone
        return val
    end

    hrp.CFrame = CFrame.new(
        betterRandom(),
        betterRandom(),
        betterRandom()
    )

    hrp.AssemblyLinearVelocity = Vector3.new(
        betterRandom(),
        betterRandom(),
        betterRandom()
    )

    hrp.AssemblyAngularVelocity = Vector3.new(
        betterRandom(),
        betterRandom(),
        betterRandom()
    )
end

local function RestorePosition()
    if not hrp or not clientCFrame then return end
    hrp.CFrame = clientCFrame
    hrp.AssemblyLinearVelocity = clientVelocity or Vector3.zero
    hrp.AssemblyAngularVelocity = clientAngularVelocity or Vector3.zero
end

--[[
    ═══════════════════════════════════════════════════════
                    ANTI AIM SYSTEM
    ═══════════════════════════════════════════════════════
]]

local glitchTick = 0
local spinAngle = 0
local stutterState = false

local function GetPitchAngle()
    local pitch = Config.AntiAim.Pitch
    if pitch == "Off" then return 0
    elseif pitch == "Up" then return 89
    elseif pitch == "Zero" then return 0
    elseif pitch == "Down" then return -89
    elseif pitch == "Glitch" then
        return math.random(-89, 89)
    elseif pitch == "Random" then
        return math.random(-89, 89)
    end
    return 0
end

local function GetYawAngle()
    local yaw = Config.AntiAim.Yaw
    local base = Config.AntiAim.YawBase
    local time = tick()

    -- Get base direction
    local baseAngle = 0
    if base == "Local" then
        if hrp then
            local _, yRot, _ = hrp.CFrame:ToEulerAnglesYXZ()
            baseAngle = math.deg(yRot)
        end
    elseif base == "At Targets" then
        local enemy = GetClosestEnemy()
        if enemy and enemy.Character and hrp then
            local enemyRoot = enemy.Character:FindFirstChild("HumanoidRootPart")
            if enemyRoot then
                local direction = (enemyRoot.Position - hrp.Position)
                baseAngle = math.deg(math.atan2(direction.X, direction.Z))
            end
        end
    end

    -- Apply yaw method
    if yaw == "Off" then
        return baseAngle + Config.AntiAim.YawAngle

    elseif yaw == "Forward" then
        return baseAngle + Config.AntiAim.YawAngle

    elseif yaw == "Backward" then
        return baseAngle + 180 + Config.AntiAim.YawAngle

    elseif yaw == "Spin" then
        spinAngle = spinAngle + 15
        if spinAngle >= 360 then spinAngle = 0 end
        return baseAngle + spinAngle + Config.AntiAim.YawAngle

    elseif yaw == "Glitch Spin" then
        spinAngle = spinAngle + math.random(10, 45)
        if spinAngle >= 360 then spinAngle = 0 end
        return baseAngle + spinAngle + Config.AntiAim.YawAngle

    elseif yaw == "Stutter Spin" then
        stutterState = not stutterState
        if stutterState then
            spinAngle = spinAngle + 90
        end
        if spinAngle >= 360 then spinAngle = 0 end
        return baseAngle + spinAngle + Config.AntiAim.YawAngle
    end

    return baseAngle + Config.AntiAim.YawAngle
end

-- Anti Aim Render Loop
RunService:BindToRenderStep("AntiAim", Enum.RenderPriority.Character.Value + 1, function()
    if not Config.AntiAim.Enabled then return end
    if not Config.Main.Enabled then return end
    if isHiding then return end

    pcall(function()
        local character = LocalPlayer.Character
        if not character then return end

        hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local pitchAngle = GetPitchAngle()
        local yawAngle = GetYawAngle()

        -- Apply anti aim angles
        hrp.CFrame = CFrame.new(hrp.Position)
            * CFrame.Angles(
                math.rad(pitchAngle),
                math.rad(yawAngle),
                0
            )
    end)
end)

