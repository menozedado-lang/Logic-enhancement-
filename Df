--[[
    ═══════════════════════════════
            TARGET FINDER
    ═══════════════════════════════
]]

local function isVisible(part)
    if not TrigCFG.VisibleCheck then return true end
    local origin = Camera.CFrame.Position
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {
        LP.Character or workspace
    }
    local result = workspace:Raycast(
        origin,
        (part.Position - origin).Unit * 500,
        params
    )
    return result
        and result.Instance
        and result.Instance:IsDescendantOf(part.Parent)
end

local function isTeammate(player)
    if not TrigCFG.TeamCheck then return false end
    return player.Team == LP.Team
end

local function isAlive(player)
    if not player.Character then return false end
    local hum = player.Character
        :FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0
end

local function getTargetParts(character)
    local parts = {}
    local wantsHead = TrigCFG.TargetPart:lower():find("head")
    local wantsBody = TrigCFG.TargetPart:lower():find("body")

    if wantsHead then
        local head = character:FindFirstChild("Head")
        if head then table.insert(parts, head) end
    end

    if wantsBody then
        local bodyParts = {
            "UpperTorso",
            "LowerTorso",
            "Torso",
            "HumanoidRootPart"
        }
        for _, name in pairs(bodyParts) do
            local part = character:FindFirstChild(name)
            if part then table.insert(parts, part) end
        end
    end

    return parts
end

local function getTriggerTarget()
    local center = Vector2.new(
        Camera.ViewportSize.X / 2,
        Camera.ViewportSize.Y / 2
    )
    local bestDist = math.huge
    local bestPart = nil
    local bestPlayer = nil

    for _, player in pairs(Players:GetPlayers()) do
        if player == LP then continue end
        if isTeammate(player) then continue end
        if not isAlive(player) then continue end

        local char = player.Character
        local parts = getTargetParts(char)

        for _, part in pairs(parts) do
            local sp, onScreen = Camera:WorldToViewportPoint(
                part.Position
            )
            if not onScreen then continue end

            local dist = (
                Vector2.new(sp.X, sp.Y) - center
            ).Magnitude

            if dist < bestDist then
                if isVisible(part) then
                    bestDist = dist
                    bestPart = part
                    bestPlayer = player
                end
            end
        end
    end

    return bestPlayer, bestPart
end

--[[
    ═══════════════════════════════
        SHOOTING FUNCTIONS
    ═══════════════════════════════
]]

local isShooting = false

local function getDelay()
    if TrigCFG.RandomDelay then
        return math.random(
            TrigCFG.MinDelay,
            TrigCFG.MaxDelay
        )
    end
    return TrigCFG.Delay
end

local function getGrace()
    return TrigCFG.Grace + math.random(-20, 20)
end

local function StartShooting()
    if isShooting then return end
    isShooting = true
    pcall(function()
        UseItemRemote:FireServer(
            "StartShooting",
            {
                CFrame = util_mod.EncodeCFrame(
                    Camera.CFrame
                ),
                State = enums_mod.FighterState
                    and enums_mod.FighterState.Shooting
                    or "Shooting",
            }
        )
    end)
end

local function StopShooting()
    if not isShooting then return end
    isShooting = false
    pcall(function()
        UseItemRemote:FireServer(
            "StopShooting",
            {
                CFrame = util_mod.EncodeCFrame(
                    Camera.CFrame
                ),
                State = enums_mod.FighterState
                    and enums_mod.FighterState.Idle
                    or "Idle",
            }
        )
    end)
end

--[[
    ═══════════════════════════════
            TRIGGERBOT LOOP
    ═══════════════════════════════
]]

local hasTarget = false
local lastTarget = nil
local graceTimer = 0

RunService.Heartbeat:Connect(function(dt)
    if not TrigCFG.On then
        if isShooting then StopShooting() end
        hasTarget = false
        graceTimer = 0
        return
    end

    local char = LP.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then
        if isShooting then StopShooting() end
        return
    end

    local targetPlayer, targetPart = getTriggerTarget()

    if targetPlayer and targetPart then
        if not hasTarget then
            hasTarget = true
            lastTarget = targetPlayer
            graceTimer = 0

            local delay = getDelay()
            task.delay(delay / 1000, function()
                if not TrigCFG.On then return end
                local stillValid, _ = getTriggerTarget()
                if stillValid == targetPlayer then
                    StartShooting()
                end
            end)
        else
            graceTimer = 0
        end
    else
        if hasTarget then
            graceTimer = graceTimer + (dt * 1000)
            if graceTimer >= getGrace() then
                hasTarget = false
                lastTarget = nil
                graceTimer = 0
                StopShooting()
            end
        end
    end
end)

