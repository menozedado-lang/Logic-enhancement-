    end)
    
    -- Method 4: Block remote detection
    for _, v in pairs(ReplicatedStorage:GetDescendants()) do
        if v:IsA("RemoteEvent") and v.Name:lower():find("cheat") or v.Name:lower():find("detect") or v.Name:lower():find("ban") then
            local oldFireServer = v.FireServer
