local utility = require(replicatedStorage.Modules.Utility)
local originalRaycast = utility.Raycast

utility.Raycast = function(...)
    local args = {...}

    if Config.SilentAim.Enabled and args[4] == 999 then
        local target = GetClosestPlayer()

        if target then
            SilentAimTarget = target

            if math.random(100) <= Config.SilentAim.HitChance then
                local targetPart = Config.SilentAim.ClosestPart
                    and GetClosestPart(target.Character)
                    or target.Character:FindFirstChild("Head")

                if targetPart then
                    args[3] = targetPart.Position
                end
            end
        else
            SilentAimTarget = nil
        end
    end

    return originalRaycast(...)
end

