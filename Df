function InitializeWeaponMods()
    local success, result = pcall(function()
        ItemLibrary = require(ReplicatedStorage.Modules.ItemLibrary)
        local Items = rawget(ItemLibrary, "Items")
        
        if not Items then
            warn("Could not get Items from ItemLibrary")
            return false
        end
        
        local WhitelistedItems = {"Bow", "Daggers", "Slingshot"}
        
        for _, Item in pairs(Items) do
            local Name = Item.Name
            if not table.find(WhitelistedItems, Name) then continue end
            if not Item["ReloadLength"] then continue end
            
            -- Store original
            OriginalReloadLengths[Name] = Item.ReloadLength
            
            -- Apply initial mod (0% = no change, 100% = instant)
            UpdateWeaponSpeed(Name, WeaponSpeedMultiplier)
        end
        
        return true
    end)
    
    if success and result then
        print("Weapon mods initialized successfully!")
        return true
    else
        warn("Failed to initialize weapon mods: " .. tostring(result))
        return false
    end
end

function UpdateWeaponSpeed(weaponName, speedPercent)
    if not ItemLibrary then return end
    
    local success = pcall(function()
        local Items = rawget(ItemLibrary, "Items")
        if not Items then return end
        
        for _, Item in pairs(Items) do
            if Item.Name == weaponName and Item["ReloadLength"] then
                local original = OriginalReloadLengths[weaponName] or Item.ReloadLength
                local newReload = original * (1 - (speedPercent / 100))
                
                -- Minimum caps for safety
                if weaponName == "Daggers" then
                    newReload = math.max(newReload, 0.01) -- Minimum 0.01s for daggers
                else
                    newReload = math.max(newReload, 0) -- Can be instant for others
                end
                
                rawset(Item, "ReloadLength", newReload)
            end
        end
    end)
    
    return success
end

function UpdateAllWeaponSpeeds(speedPercent)
    WeaponSpeedMultiplier = speedPercent
    
    local weapons = {"Bow", "Daggers", "Slingshot"}
    for _, weapon in ipairs(weapons) do
        UpdateWeaponSpeed(weapon, speedPercent)
    end
end

function ResetWeaponSpeeds()
    for weaponName, originalLength in pairs(OriginalReloadLengths) do
        UpdateWeaponSpeed(weaponName, 0) -- 0% means original speed
    end
end

