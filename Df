local VoidMethods = {}

-- 1. Extreme Desync
VoidMethods["Extreme Desync"] = function()
    local intensity = Config.VoidSpam.Intensity / 100
    local range = 2147483646 * intensity
    local deadZone = 1147483646 * intensity
    
    hrp.CFrame = CFrame.new(
        betterRandom(-range, range, -deadZone, deadZone),
        betterRandom(-range, range, -deadZone, deadZone),
        betterRandom(-range, range, -deadZone, deadZone)
    ) * CFrame.Angles(math.rad(math.pi), math.rad(math.pi), math.rad(math.pi))
    
    hrp.AssemblyLinearVelocity = Vector3.new(
        betterRandom(-range, range, -deadZone, deadZone),
        betterRandom(-range, range, -deadZone, deadZone),
        betterRandom(-range, range, -deadZone, deadZone)
    )
    
    hrp.AssemblyAngularVelocity = Vector3.new(
        betterRandom(-range, range, -deadZone, deadZone),
        betterRandom(-range, range, -deadZone, deadZone),
        betterRandom(-range, range, -deadZone, deadZone)
    )
end

-- 2. Projectile TP Method
VoidMethods["Projectile TP"] = function()
    local altitude = Config.VoidSpam.Altitude
    local currentPos = clientCFrame.Position
    
    hrp.CFrame = CFrame.new(
        currentPos.X + math.random(-100, 100),
        altitude,
        currentPos.Z + math.random(-100, 100)
    )
    
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
end

-- 3. Orbital Void
VoidMethods["Orbital Void"] = function()
    local altitude = Config.VoidSpam.Altitude
    local time = tick()
    local radius = 50
    
    hrp.CFrame = CFrame.new(
        math.sin(time * 2) * radius,
        altitude,
        math.cos(time * 2) * radius
    )
    
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
end

-- 4. Controlled Void
VoidMethods["Controlled Void"] = function()
    local altitude = Config.VoidSpam.Altitude
    
    hrp.CFrame = CFrame.new(
        betterRandom(-1000, 1000, -500, 500),
        altitude,
        betterRandom(-1000, 1000, -500, 500)
    )
    
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
end

-- 5. Seizure Mode
VoidMethods["Seizure Mode"] = function()
    local positions = {
        Vector3.new(100000, 100000, 100000),
        Vector3.new(-100000, 100000, -100000),
        Vector3.new(100000, -100000, 100000),
        Vector3.new(-100000, -100000, -100000),
    }
    
    local index = math.floor(tick() * 10) % #positions + 1
    hrp.CFrame = CFrame.new(positions[index])
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
end

--[[
    ═══════════════════════════════════════════════════════
                    PROJECTILE TP SYSTEM
    ═══════════════════════════════════════════════════════
]]

local function FindCoreProjectile()
    for _, obj in ipairs(Workspace:GetChildren()) do
        if obj.Name == "CoreProjectile" and obj:FindFirstChild("TouchInterest") then
            return obj
        end
    end
    return nil
end

local function GetEnemyHitbox(enemy)
    if not enemy or not enemy.Character then return nil end
    
    local targetPart = Config.ProjectileTP.TargetPart
    local hitbox = enemy.Character:FindFirstChild(targetPart)
    
    if not hitbox then
        hitbox = enemy.Character:FindFirstChild("HitBoxHead")
            or enemy.Character:FindFirstChild("HitBoxHeadSmall")
            or enemy.Character:FindFirstChild("Head")
    end
    
    return hitbox
end

Connections.ProjectileTP = RunService.Heartbeat:Connect(function()
    if not Config.ProjectileTP.Enabled then return end
    
    pcall(function()
        local projectile = FindCoreProjectile()
        
        if projectile then
            if Config.ProjectileTP.Cache and not ProjectileCache[projectile] then
                ProjectileCache[projectile] = true
            end
            
            CacheEnemies()
            
            for _, enemy in ipairs(EnemyCache) do
                local hitbox = GetEnemyHitbox(enemy)
                
                if hitbox then
                    firetouchinterest(projectile, hitbox, 0)
                    task.wait(Config.ProjectileTP.LoopDelay)
                    firetouchinterest(projectile, hitbox, 1)
                end
            end
        end
    end)
end)

--[[
    ═══════════════════════════════════════════════════════
                    RAGEBOT
    ═══════════════════════════════════════════════════════
]]

Connections.Ragebot = RunService.Heartbeat:Connect(function()
    if not Config.Ragebot.Enabled then return end
    
    pcall(function()
        local enemy = GetClosestEnemy()
        
        if enemy and enemy.Character then
            local enemyRoot = enemy.Character:FindFirstChild("HumanoidRootPart")
            
            if enemyRoot and Config.Ragebot.ClientTP then
                local playerRoot = LocalPlayer.Character.HumanoidRootPart
                
                local time = tick() * Config.Ragebot.OrbitSpeed
                local radius = Config.Ragebot.OrbitRadius
                
                local offset = Vector3.new(
                    math.sin(time) * radius,
                    0,
                    math.cos(time) * radius
                )
                
                enemyRoot.CFrame = CFrame.new(playerRoot.Position + offset)
            end
        end
    end)
end)

--[[
    ═══════════════════════════════════════════════════════
                    VOID SPAM MAIN SYSTEM
    ═══════════════════════════════════════════════════════
]]

Connections.VoidHeartbeat = RunService.Heartbeat:Connect(function()
    if not Config.VoidSpam.Enabled then return end
    
    pcall(function()
        hrp = LocalPlayer.Character.HumanoidRootPart
        
        clientCFrame = hrp.CFrame
        clientVelocity = hrp.AssemblyLinearVelocity
        clientAngularVelocity = hrp.AssemblyAngularVelocity
        
        local method = VoidMethods[Config.VoidSpam.Method]
        if method then
            method()
        end
    end)
end)

Connections.VoidRender = RunService:BindToRenderStep("VoidRestore", Enum.RenderPriority.First.Value, function()
    if hrp and Config.VoidSpam.Enabled then
        pcall(function()
            hrp.CFrame = clientCFrame
            hrp.AssemblyLinearVelocity = clientVelocity
            hrp.AssemblyAngularVelocity = clientAngularVelocity
        end)
    end
end)

