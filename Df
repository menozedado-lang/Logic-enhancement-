            if current and typeof(current) == "string" then
                for _, old in ipairs(oldIds) do
                    if current:find(old) then
                        sky[prop] = DARK_SKY_ID
                        replaced = true
                        break
                    end
                end
            end
        end

        if not replaced then
            for _, prop in ipairs({
                "SkyboxBk", "SkyboxDn", "SkyboxFt",
                "SkyboxLf", "SkyboxRt", "SkyboxUp"
            }) do
                sky[prop] = DARK_SKY_ID
            end
        end

        local snowPart = Instance.new("Part")
        snowPart.Size = Vector3.new(100, 1, 100)
        snowPart.Transparency = 1
        snowPart.CanCollide = false
        snowPart.Anchored = true
        snowPart.Parent = workspace

        local emitter = Instance.new("ParticleEmitter")
        emitter.Texture = "rbxassetid://5833323391"
        emitter.Color = ColorSequence.new(
            Color3.fromRGB(255, 255, 255)
        )
        emitter.Size = NumberSequence.new(0.6)
        emitter.Transparency = NumberSequence.new(0)
        emitter.Lifetime = NumberRange.new(12, 20)
        emitter.Rate = 150
        emitter.Speed = NumberRange.new(5, 10)
        emitter.SpreadAngle = Vector2.new(30, 30)
        emitter.Acceleration = Vector3.new(0, -7, 0)
        emitter.Rotation = NumberRange.new(0, 360)
        emitter.RotSpeed = NumberRange.new(-30, 30)
        emitter.Parent = snowPart

        runService.RenderStepped:Connect(function()
            if snowPart and snowPart.Parent then
                snowPart.Position = Camera.CFrame.Position
                    + Vector3.new(0, 35, 0)
            end
        end)

        Library:Notify('❄️ Dark Sky + Snow enabled!', 5)
    end
})

