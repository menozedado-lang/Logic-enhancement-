-- Roll for swords
local function RollSword(amount)
    for i = 1, amount do
        local success, result = pcall(function()
            return SwordRollRequest:InvokeServer()
        end)
        
        if success and result then
            table.insert(RolledSwords, result)
            Rayfield:Notify({
                Title = "🎲 Roll Result",
                Content = "Rolled: " .. tostring(result),
                Duration = 2
            })
        end
        
        wait(0.5) -- Prevent spam detection
    end
end

