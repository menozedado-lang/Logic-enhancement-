                humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
                    if WalkSpeedEnabled and humanoid.WalkSpeed ~= WalkSpeedValue then
                        humanoid.WalkSpeed = WalkSpeedValue
                    end
                end)
