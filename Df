end

func enableFly()
    local character = LocalPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    
    if not humanoid or not rootPart then return end
    
    -- Create BodyVelocity for movement
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = rootPart
    
    -- Create BodyGyro for rotation
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bodyGyro.P = 10000
    bodyGyro.Parent = rootPart
    
    -- Disable gravity
    humanoid.PlatformStand = true
    
    -- Fly loop
    flyConnection = RunService.RenderStepped:Connect(func()
        if not flyEnabled then return end
        
        local moveDir = Vector3.new(0, 0, 0)
        
        -- Keyboard input (PC)
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            moveDir = moveDir + Camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            moveDir = moveDir - Camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            moveDir = moveDir - Camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            moveDir = moveDir + Camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            moveDir = moveDir + Vector3.new(0, 1, 0)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
            moveDir = moveDir - Vector3.new(0, 1, 0)
        end
        
        -- Mobile input
        if mobileFlyEnabled then
            -- Use thumbstick or touch
            local touchMove = moveVector
            moveDir = moveDir + (Camera.CFrame.LookVector * touchMove.Z + Camera.CFrame.RightVector * touchMove.X)
        end
        
        -- Normalize and apply speed
        if moveDir.Magnitude > 0 then
            moveDir = moveDir.Unit * flySpeed
        end
        
        -- Update velocity
        if bodyVelocity then
            bodyVelocity.Velocity = moveDir
        end
        
        -- Update gyro to match camera
        if bodyGyro then
            bodyGyro.CFrame = Camera.CFrame
        end
    end)
    
    flyEnabled = true
end

func disableFly()
    flyEnabled = false
    
    if flyConnection then
        flyConnection:Disconnect()
        flyConnection = nil
    end
    
    if bodyVelocity then
        bodyVelocity:Destroy()
        bodyVelocity = nil
    end
    
    if bodyGyro then
        bodyGyro:Destroy()
        bodyGyro = nil
    end
    
    local character = LocalCharacter
    if character then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.PlatformStand = false
        end
    end
end

func toggleFly()
    if flyEnabled then
        disableFly()
        if flyButton then
            flyButton.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
            flyButton.Text = "FLY"
        end
        if upButton then upButton.Visible = false end
        if downButton then downButton.Visible = false end
    else
        enableFly()
        if flyButton then
            flyButton.BackgroundColor3 = Color3.fromRGB(255, 170, 0)
            flyButton.Text = "STOP"
        end
        if upButton then upButton.Visible = true end
        if downButton then downButton.Visible = true end
    end
end

func setupMobileControls()
    createMobileGUI()
    
    -- Fly button
    flyButton.MouseButton1Click:Connect(func()
        toggleFly()
    end)
    
    -- Up button (hold)
    local upConnection = nil
    upButton.InputBegan:Connect(func(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            upConnection = RunService.RenderStepped:Connect(func()
                if bodyVelocity then
                    bodyVelocity.Velocity = bodyVelocity.Velocity + Vector3.new(0, verticalSpeed, 0)
                end
            end)
        end
    end)
    
    upButton.InputEnded:Connect(func(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            if upConnection then
                upConnection:Disconnect()
                upConnection = nil
            end
        end
    end)
    
    -- Down button (hold)
    local downConnection = nil
    downButton.InputBegan:Connect(func(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            downConnection = RunService.RenderStepped:Connect(func()
                if bodyVelocity then
                    bodyVelocity.Velocity = bodyVelocity.Velocity - Vector3.new(0, verticalSpeed, 0)
                end
            end)
        end
    end)
    
    downButton.InputEnded:Connect(func(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            if downConnection then
                downConnection:Disconnect()
                downConnection = nil
            end
        end
    end)
    
    -- Touch movement (thumbstick style)
    local touchStartPos = nil
    local touchGui = Instance.new("ScreenGui")
    touchGui.Name = "TouchControls"
    touchGui.ResetOnSpawn = false
    
    local touchFrame = Instance.new("Frame")
    touchFrame.Name = "TouchFrame"
    touchFrame.Size = UDim2.new(0, 150, 0, 150)
    touchFrame.Position = UDim2.new(0, 20, 1, -170)
    touchFrame.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    touchFrame.BackgroundTransparency = 0.5
    touchFrame.BorderSizePixel = 0
    touchFrame.Visible = false
    touchFrame.Parent = touchGui
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0.5, 0)
    corner.Parent = touchFrame
    
    local knob = Instance.new("Frame")
    knob.Name = "Knob"
    knob.Size = UDim2.new(0, 50, 0, 50)
    knob.Position = UDim2.new(0.5, -25, 0.5, -25)
    knob.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    knob.BorderSizePixel = 0
    knob.Parent = touchFrame
    
    local corner2 = Instance.new("UICorner")
    corner2.CornerRadius = UDim.new(0.5, 0)
    corner2.Parent = knob
    
    if syn then
        touchGui.Parent = game:GetService("CoreGui")
    else
        touchGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    end
    
    -- Touch handling
    local activeTouch = nil
    
    touchFrame.InputBegan:Connect(func(input)
        if input.UserInputType == Enum.UserInputType.Touch and not activeTouch then
            activeTouch = input
            touchStartPos = Vector2.new(input.Position.X, input.Position.Y)
            touchFrame.Visible = true
        end
    end)
    
    UserInputService.InputChanged:Connect(func(input)
        if input == activeTouch then
            local delta = Vector2.new(input.Position.X, input.Position.Y) - touchStartPos
            local maxDist = 50
            
            if delta.Magnitude > maxDist then
                delta = delta.Unit * maxDist
            end
            
            knob.Position = UDim2.new(0.5, delta.X - 25, 0.5, delta.Y - 25)
            
            -- Normalize to -1 to 1
            moveVector = Vector3.new(delta.X / maxDist, 0, -delta.Y / maxDist)
            mobileFlyEnabled = true
        end
    end)
    
    UserInputService.InputEnded:Connect(func(input)
        if input == activeTouch then
            activeTouch = nil
            knob.Position = UDim2.new(0.5, -25, 0.5, -25)
            moveVector = Vector3.new(0, 0, 0)
            mobileFlyEnabled = false
        end
    end)
end

func setupPCControls()
    UserInputService.InputBegan:Connect(func(input, gameProcessed)
        if gameProcessed then return end
        
        if input.KeyCode == Enum.KeyCode.F then
            toggleFly()
        end
        
        if input.KeyCode == Enum.KeyCode.LeftShift then
            flySpeed = flySpeed * 2
        end
    end)
    
    UserInputService.InputEnded:Connect(func(input)
        if input.KeyCode == Enum.KeyCode.LeftShift then
            flySpeed = flySpeed / 2
        end
    end)
end

func init()
    -- Detect if mobile
    local isMobile = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
    
    if isMobile then
        setupMobileControls()
    else
        setupPCControls()
    end
    
    -- Handle character respawn
    LocalPlayer.CharacterAdded:Connect(func(char)
        if flyEnabled then
            wait(0.5)
            disableFly()
            wait(0.1)
            enableFly()
        end
    end)
    
    print("Fly script loaded! Press F to fly (PC) or use the GUI (Mobile)")
end

-- Start
init()
]]
