-- Get Character
local function GetCharacter()
    return LocalPlayer.Character or LocalPlayer:WaitForChild("Character")
end

-- Get Humanoid
local function GetHumanoid()
    local character = GetCharacter()
    if character then
        return character:FindFirstChildOfClass("Humanoid")
    end
    return nil
end

-- Get equipped sword
local function GetEquippedSword()
    local character = GetCharacter()
    if character then
        for _, tool in pairs(character:GetChildren()) do
            if tool:IsA("Tool") and (tool:FindFirstChild("SwordScript") or tool.Name:find("Sword")) then
                return tool
            end
        end
    end
    return nil
end

-- Equip best sword
local function EquipBestSword()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return end
    
    local bestTool = nil
    local bestDamage = 0
    
    for _, tool in pairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then
            -- Check for damage value
            local damage = 0
            if tool:FindFirstChild("Damage") then
                damage = tool.Damage.Value
            elseif tool:FindFirstChild("Stats") and tool.Stats:FindFirstChild("Damage") then
                damage = tool.Stats.Damage.Value
            end
            
            -- Check config module
            local config = tool:FindFirstChild("Configuration") or tool:FindFirstChild("Settings")
            if config and config:FindFirstChild("Damage") then
                damage = config.Damage.Value
            end
            
            if damage > bestDamage then
                bestDamage = damage
                bestTool = tool
            end
        end
    end
    
    if bestTool then
        local humanoid = GetHumanoid()
        if humanoid then
            humanoid:EquipTool(bestTool)
            BestSword = bestTool.Name
            Rayfield:Notify({
                Title = "⚔️ Auto Equip",
                Content = "Equipped: " .. bestTool.Name .. " (DMG: " .. bestDamage .. ")",
                Duration = 3
            })
        end
    end
end

