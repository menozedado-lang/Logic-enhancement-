end)

--[[
    ═══════════════════════════════════════════════════════
                    RAGEBOT LOOP
    ═══════════════════════════════════════════════════════
]]

local function RagebotLoop()
    while Config.Ragebot.Enabled do
        pcall(function()
            local character = LocalPlayer.Character
            if not character then return end

            hrp = character:FindFirstChild("HumanoidRootPart")
            if not hrp then return end

            -- Store real position
            clientCFrame = hrp.CFrame
            clientVelocity = hrp.AssemblyLinearVelocity
            clientAngularVelocity = hrp.AssemblyAngularVelocity

            -- HIDE PHASE
            isHiding = true
            isAttacking = false

            if Config.Ragebot.VoidSpam then
                ApplyVoid()
            end

            task.wait(Config.Ragebot.HideTime)

            -- ATTACK PHASE
            isHiding = false
            isAttacking = true

            RestorePosition()

            -- Shoot attempts
            for i = 1, Config.Ragebot.ShootAttempts do
                pcall(function()
                    local tool = character:FindFirstChildOfClass("Tool")
                    if tool then
                        local enemy = GetClosestEnemy()
                        if enemy and enemy.Character then
                            local enemyHead = enemy.Character:FindFirstChild("Head")
                            if enemyHead and hrp then
                                hrp.CFrame = CFrame.lookAt(
                                    hrp.Position,
                                    enemyHead.Position
                                )
                            end
                        end
                        tool:Activate()
                    end
                end)

                if i < Config.Ragebot.ShootAttempts then
                    task.wait(0.01)
                end
            end

            task.wait(Config.Ragebot.AttackTime)
            isAttacking = false
        end)
    end
end

--[[
    ═══════════════════════════════════════════════════════
                    RENDER RESTORE
    ═══════════════════════════════════════════════════════
]]

RunService:BindToRenderStep("VoidRestore", Enum.RenderPriority.First.Value, function()
    if hrp and clientCFrame and isAttacking then
        pcall(RestorePosition)
    end
end)

